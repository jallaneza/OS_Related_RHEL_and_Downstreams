#!/bin/bash

# Script that will install packages needed, update kernel
# for the Kickstart install of CentOS 8.3 on the Thinkpad L15

export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/root/bin

function logaction() {
   logger -t 'install_and_config_packages.sh' -p local1.info $1
}

# Install the keys to avoid yum to request confirmation on install
logaction 'Importing CentOS GPG Keys'
rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-centosofficial
rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-EPEL-8
rpm --import https://dl.google.com/linux/linux_signing_key.pub

# Install packages needed for VMWare Workstation 16 modules compilation
logaction 'Installing packages to fullfill dependencies'
yum -y install gcc kernel-devel make glibc-headers libaio elfutils-libelf-devel SDL qt5-qtx11extras qt5-qtlocation qt5-qtquickcontrols qt5-qtsensors qt5-qtwebchannel qt5-qtwebkit minizip1.2 libXScrnSaver gnome-tweaks --enablerepo=myappstream,myepel

# Install Google Chrome (current as of May 18, 2022)
logaction 'Installing Google Chrome'
yum -y install google-chrome-stable --enablerepo=*

# We take some time
logaction 'Sleeping 5'
sleep 5

# Update kernel so the version matches the kernel-headers installed version
logaction 'Updating Kernel'
yum -y update kernel

# We installed Teamviewer
logaction 'Installing Teamviewer'
yum -y install /root/teamviewer_15.29.4.x86_64.rpm

# We remove the repository configuration file that was installed
# in the step above
logaction 'Removing Teamviewer repo'
rm -f /etc/yum.repos.d/teamviewer.repo

# We remove the line containing this script in the rc.local file
logaction 'Removing this script from rc.local'
sed -i.bkp '15d' /etc/rc.d/rc.local

# We set the correct permissions on the rc.local
logaction 'Setting correct permissions for rc.local'
chmod -x /etc/rc.d/rc.local

# We install VMWare Workstation 16
logaction 'Installing VMWare Workstation 16'
#/root/VMware-Workstation-Full-16.1.0-17198959.x86_64.bundle
/root/VMware-Workstation-Full-16.2.3-19376536.x86_64.bundle

# We take some time
logaction 'Sleeping 5'
sleep 5

# Install VirtualBox
logaction 'Installing Virtualbox 6.1.34'
yum -y install /root/VirtualBox-6.1-6.1.34_150636_el8-2.x86_64.rpm

# We take some time
logaction 'Sleeping 5'
sleep 5

# Install VirtualBox Extension
logaction 'Installing Virtualbox Extension Pack'
vboxmanage extpack install --accept-license=33d7284dc4a0ece381196fda3cfe2ed0e1e8e7ed7f27b9a9ebc4ee22e24bd23c /root/Oracle_VM_VirtualBox_Extension_Pack-6.1.34.vbox-extpack

# We take some time
logaction 'Sleeping 5'
sleep 5

# We put the desktop icons in the corresponding directory
logaction 'Copying desktop icons'
mkdir -p /home/javier/Desktop
chown javier.javier /home/javier/Desktop
mv /root/*.desktop /home/javier/Desktop/
chown javier.javier /home/javier/Desktop/*
chmod u+x /home/javier/Desktop/*

# We remove this file
logaction 'Removing script from the home of the root user'
rm -f /root/install_and_config_packages.sh

# Pausing before rebooting to allow for complete log
logaction 'Pausing before rebooting'
sleep 10

# We reboot the system so the new kernel takes over
reboot

