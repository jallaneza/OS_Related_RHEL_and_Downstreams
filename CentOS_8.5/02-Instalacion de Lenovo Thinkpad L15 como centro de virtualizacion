# Root password
rootpw --iscrypted $6$..mxVK2aru5eMaV1$4HSef4.7/2zDU3Ncg.sKGCL6tXhS1JzE5KrBFgbMSAWlMlv6RPCqin6b70B16A6D7zEMm0946uZKAI2vYwwbU.

# Create user
user --name=javier --groups=wheel --iscrypted --password=$6$..mxVK2aru5eMaV1$4HSef4.7/2zDU3Ncg.sKGCL6tXhS1JzE5KrBFgbMSAWlMlv6RPCqin6b70B16A6D7zEMm0946uZKAI2vYwwbU.

