# Partition clearing information
clearpart --all --initlabel --drives=nvme0n1

# Disk partitioning information for 1 TB
part swap --fstype="swap" --ondisk=nvme0n1 --size=21000
part /boot --fstype="xfs"  --ondisk=nvme0n1 --size=1024
part pv.593 --fstype="lvmpv" --ondisk=nvme0n1 --size=931844
volgroup rootvg --pesize=4096 pv.593
