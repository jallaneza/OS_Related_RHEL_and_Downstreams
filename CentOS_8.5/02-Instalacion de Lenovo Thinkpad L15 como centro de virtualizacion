#
# Kickstart configuration file for installing CentOS 8.5
# on my Thinkpad L15 with Teamviewer, VirtualBox 6.1 and VMWare Workstation 16
#

# This is not used in CentOS 8.5 as caused an error in the kickstart install
# System authorization information
# auth --enableshadow --passalgo=sha512

# Use network installation adding the AppStream Repo, which is the one that came
# in the full install ISO. This is because there was a difference between that repository
# and the repository accessible via HTTP. That difference made the install fail
repo --name appstreamkickstartrepo  --baseurl http://nuc480e.zanella.net/centos8.5/AppStream/x86_64/kickstart/

# Use CDROM installation media
# cdrom

# Use text mode install
# text

# Do not run the Setup Agent on first boot
firstboot --disabled

# Auto accept the EULA
eula --agreed

# Use the only disk on the system
ignoredisk --only-use=nvme0n1

# Keyboard layout
keyboard --vckeymap=la-latin1 --xlayouts='latam'

# System language
lang en_US.UTF-8

# Network information. This is not needed as I have a DHCP server and DNS that provides
# direct and reverse resolution. The hostname is set via a reverse DNS query
#network  --bootproto=dhcp --device=enp0s3 --ipv6=auto --activate
#network  --hostname=splunk.zanellalab.com

