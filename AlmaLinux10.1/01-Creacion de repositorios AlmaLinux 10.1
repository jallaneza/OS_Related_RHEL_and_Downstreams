almalinux-highavailability.repo:# baseurl=https://vault.almalinux.org/$releasever/HighAvailability/Source/
almalinux-nfv.repo:# baseurl=https://repo.almalinux.org/almalinux/$releasever/NFV/$basearch/os/
almalinux-nfv.repo:# baseurl=https://vault.almalinux.org/$releasever/NFV/debug/$basearch/
