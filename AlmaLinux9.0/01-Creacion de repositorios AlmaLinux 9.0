  almalinux-resilientstorage.repo:# baseurl=https://repo.almalinux.org/almalinux/$releasever/ResilientStorage/$basearch/os/
  almalinux-resilientstorage.repo:# baseurl=https://repo.almalinux.org/vault/$releasever/ResilientStorage/debug/$basearch/
  almalinux-resilientstorage.repo:# baseurl=https://repo.almalinux.org/vault/$releasever/ResilientStorage/Source/
  almalinux-rt.repo:# baseurl=https://repo.almalinux.org/almalinux/$releasever/RT/$basearch/os/
  almalinux-rt.repo:# baseurl=https://repo.almalinux.org/vault/$releasever/RT/debug/$basearch/
  almalinux-rt.repo:# baseurl=https://repo.almalinux.org/vault/$releasever/RT/Source/
  almalinux-saphana.repo:# baseurl=https://repo.almalinux.org/almalinux/$releasever/SAPHANA/$basearch/os/
  almalinux-saphana.repo:# baseurl=https://repo.almalinux.org/vault/$releasever/SAPHANA/debug/$basearch/
